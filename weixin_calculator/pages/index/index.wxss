.page {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  padding: 24rpx 0;
}

.calculator {
  width: 92%;
  background-color: #e6f4ff;
  padding: 50rpx;
  border-radius: 70rpx;
  box-shadow: 0 0 30rpx #55a8ee;
  box-sizing: border-box;
}

.screen {
  width: 100%;
  height: 220rpx;
  background-color: #ffffff;
  border-radius: 50rpx;
  font-size: 84rpx;
  text-align: right;
  padding-right: 40rpx;
  margin-bottom: 40rpx;
  color: #0066cc;
  line-height: 220rpx;
  box-sizing: border-box;
}

.row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.equal-row {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 20rpx;
}

/* 宽高必须一致才是正圆；百分比宽度 + 固定高度 rpx 会拉成椭圆 */
.btn {
  flex-shrink: 0;
  width: 136rpx;
  height: 136rpx;
  min-width: 136rpx;
  min-height: 136rpx;
  border-radius: 50%;
  border: none;
  padding: 0;
  margin: 10rpx 0;
  font-size: 56rpx;
  font-weight: bold;
  line-height: normal;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.num {
  background-color: #b3d9ff;
  color: #0055aa;
}

.op {
  background-color: #66b2ff;
  color: #ffffff;
}

.clear {
  background-color: #3399ff;
  color: #ffffff;
}

.equal {
  width: 296rpx;
  height: 136rpx;
  min-height: 136rpx;
  border-radius: 68rpx !important;
  background-color: #0077dd;
  color: #ffffff;
  font-size: 60rpx;
  line-height: normal;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-hover {
  opacity: 0.88;
}

.btn-hover-equal {
  opacity: 0.88;
}
