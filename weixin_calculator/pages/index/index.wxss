.page {
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  padding: 24rpx 0;
}

.calculator {
  width: 92%;
  max-width: 100%;
  background-color: #e6f4ff;
  padding: 40rpx 32rpx;
  border-radius: 70rpx;
  box-shadow: 0 0 30rpx #55a8ee;
  box-sizing: border-box;
  overflow: hidden;
}

.screen {
  width: 100%;
  height: 220rpx;
  background-color: #ffffff;
  border-radius: 50rpx;
  font-size: 84rpx;
  text-align: right;
  padding-right: 40rpx;
  margin-bottom: 40rpx;
  color: #0066cc;
  line-height: 220rpx;
  box-sizing: border-box;
}

.keypad {
  width: 100%;
  box-sizing: border-box;
}

/* 四列等分，防止右侧被裁切、防止键被拉成椭圆 */
.row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  column-gap: 16rpx;
  margin-bottom: 16rpx;
  align-items: center;
}

.row-equal {
  margin-bottom: 0;
}

.row-equal-spacer {
  min-height: 1rpx;
  pointer-events: none;
}

/* 圆形键：列宽即直径，aspect-ratio 保证高与宽相等 */
.tap.btn {
  width: 100%;
  aspect-ratio: 1;
  box-sizing: border-box;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
  font-weight: bold;
  line-height: 1;
}

/* 跨两列 + 中间缝，与 HTML 里两圆加间距同宽；高度与圆键直径一致 */
.tap.btn.equal {
  aspect-ratio: auto;
  width: auto;
  height: calc((100% - 48rpx) / 4);
  border-radius: 999rpx;
  margin-top: 0;
  font-size: 58rpx;
}

.num {
  background-color: #b3d9ff;
  color: #0055aa;
}

.op {
  background-color: #66b2ff;
  color: #ffffff;
}

.clear {
  background-color: #3399ff;
  color: #ffffff;
}

.equal {
  background-color: #0077dd;
  color: #ffffff;
}

.btn-hover {
  opacity: 0.88;
}

.btn-hover-equal {
  opacity: 0.88;
}
